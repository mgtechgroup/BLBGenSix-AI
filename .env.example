APP_NAME="BLBGenSix AI"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://blbgensixai.club
APP_LOCALE=en

# Domain & Security
APP_DOMAIN=blbgensixai.club
TRUSTED_PROXIES=Cloudflare,AWS
ALLOWED_ORIGINS=https://blbgensixai.club,https://www.blbgensixai.club
HASH_PEPPER=

# Adult Verification
ADULT_VERIFICATION_REQUIRED=true
MIN_AGE=18
DEVICE_FINGERPRINT_REQUIRED=true
MAX_DEVICES_PER_USER=3

# Zero Trust Security - STRICT PASSWORDLESS
ZERO_TRUST_ALWAYS_VERIFY=true
BIOMETRIC_REQUIRED=true
PASSKEY_FALLBACK=true
DEVICE_BINDING=true
SESSION_ROTATION=900
IP_VALIDATION=true
ENFORCE_PASSWORDLESS=true
ALLOW_PASSWORD_AUTH=false

# Database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=blbgensixai
DB_USERNAME=blbgensixai_user
DB_PASSWORD=

# Redis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_CACHE_DB=1
REDIS_SESSION_DB=2
REDIS_QUEUE_DB=3

# Queue
QUEUE_CONNECTION=redis

# Session
SESSION_DRIVER=database
SESSION_LIFETIME=60
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict

# AI Providers
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_ORGANIZATION=
IMAGE_MODEL=stable-diffusion-xl
VIDEO_MODEL=modelscope
TEXT_MODEL=gpt-4
BODY_MODEL=smplx
MAX_CONCURRENT_GENERATIONS=4

# Stripe
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=price_starter
STRIPE_PRICE_PRO=price_pro
STRIPE_PRICE_ENTERPRISE=price_enterprise

# PayPal
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_MODE=live

# Cash App
CASHAPP_CLIENT_ID=
CASHAPP_CLIENT_SECRET=

# Crypto / Blockchain
BLOCKCHAIN_PROVIDER=alchemy
ALCHEMY_API_KEY=
ALCHEMY_POLYGON_KEY=
ALCHEMY_BSC_KEY=
COINGECKO_API_KEY=

# Crypto Deposit Addresses
CRYPTO_DEPOSIT_ETH=0xYourEthereumAddress
CRYPTO_DEPOSIT_BTC=bc1YourBitcoinAddress
CRYPTO_DEPOSIT_MATIC=0xYourPolygonAddress
CRYPTO_DEPOSIT_SOL=YourSolanaAddress
CRYPTO_DEPOSIT_BNB=0xYourBSCAddress

# Cold Wallet Policy
COLD_WALLET_ONLY=true
ALLOW_HOT_WALLETS=false
MIN_VERIFICATION_SCORE=0.90

# Income Automation
OF_ENABLED=false
OF_API_KEY=
FANSLY_ENABLED=false
FANSLY_API_KEY=
MV_ENABLED=false
MV_API_KEY=
JFF_ENABLED=false
JFF_API_KEY=
POSTS_PER_DAY=3

# Ad Networks
ADSTERRA_API_KEY=
EXOCHECK_API_KEY=
TRAFFICJUNKY_API_KEY=

# File Storage
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=blbgensixai-storage
AWS_URL=

# Mail
MAIL_MAILER=smtp
MAIL_HOST=smtp.postmarkapp.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@blbgensixai.club"
MAIL_FROM_NAME="BLBGenSix AI"

# Horizon
HORIZON_PREFIX=blbgensixai-
HORIZON_DASHBOARD_AUTH=true

# Monitoring
SENTRY_DSN=
PROMETHEUS_ENABLED=true
